{
  "name": "agent-go-round",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "predev": "node scripts/sync-graphify.mjs",
    "dev": "vite",
    "prebuild": "node scripts/sync-graphify.mjs",
    "build": "tsc -b && vite build",
    "lint": "eslint src --max-warnings 0",
    "preview": "vite preview",
    "deploy": "vite build && gh-pages -d dist",
    "test": "vitest run",
    "test:tutorial": "tsx scripts/tutorial-runtime-check.ts",
    "test:real_tutorial": "tsx scripts/real-tutorial-runner.ts"
  },
  "dependencies": {
    "jszip": "^3.10.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "yaml": "^2.8.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/json-schema": "^7.0.15",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "gh-pages": "^6.3.0",
    "jsdom": "^27.0.1",
    "tsx": "^4.21.0",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.59.0",
    "vite": "^6.0.0",
    "vitest": "^3.2.4"
  }
}
